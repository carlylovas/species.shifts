Package: species.shifts
Type: Package
Title: Northeast US Marine Species Distribution Shifts
Version: 0.1.0
Authors@R: c(
    person(
      "Carly", "Lovas",
      email = "carly.lovas@gmail.com",
      role = "Quantitative Research Associate, GMRI"
    )
